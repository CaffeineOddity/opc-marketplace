{
  "name": "product-design",
  "description": "产品设计流程：需求说明 + 功能页面归类 + 交互稿",
  "triggers": {
    "keywords": ["产品设计", "产品设计流程", "需求设计", "product design"],
    "patterns": []
  },
  "pipeline": [
    {
      "stage": "product",
      "required": true,
      "outputs": ["spec.md", "feature-list.md", "page-categories.md"],
      "agents": ["product-agent", "business-analyst"],
      "agent_mode": "parallel",
      "skills": ["spec-driven-development", "requirement"],
      "description": "需求说明、功能页面归类（并行）"
    },
    {
      "stage": "design",
      "required": true,
      "outputs": ["interaction-spec.md", "wireframes/", "ui-spec.md"],
      "agents": ["web-agent", "mobile-agent", "design-reviewer"],
      "agent_mode": "sequential",
      "skills": ["ui-design", "ui-ux-pro-max"],
      "description": "交互稿、UI 规范（串行：先设计后评审）"
    },
    {
      "stage": "review",
      "required": true,
      "outputs": ["design-review.md"],
      "agents": ["design-reviewer"],
      "skills": [],
      "description": "设计评审"
    }
  ],
  "gates": [
    {
      "name": "product_complete",
      "description": "Product 输出完整才能开始 Design",
      "check": "stages.product.artifacts.includes('spec.md') && stages.product.artifacts.includes('page-categories.md')",
      "blocker": "Design 阻止：请先完成需求说明和功能页面归类。"
    },
    {
      "name": "design_review_pass",
      "description": "设计评审通过才能进入 Dev",
      "check": "stages.review.status === 'completed' && stages.review.review_passed === true",
      "blocker": "Dev 阻止：设计评审未通过。"
    }
  ],
  "rules": {
    "tdd": false,
    "sdd": true,
    "parallel_allowed": false
  },
  "execution_flow": {
    "product": {
      "sequence": 1,
      "next": ["design"],
      "outputs_required": ["spec.md", "feature-list.md", "page-categories.md"]
    },
    "design": {
      "sequence": 2,
      "next": ["review"],
      "outputs_required": ["interaction-spec.md", "wireframes/"]
    },
    "review": {
      "sequence": 3,
      "next": []
    }
  }
}