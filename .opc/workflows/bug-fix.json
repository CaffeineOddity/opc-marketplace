{
  "name": "bug-fix",
  "description": "Bug fix with Diagnosis + TDD",
  "triggers": {
    "keywords": ["修复", "bug", "错误", "崩溃", "问题", "fix", "error", "crash", "issue", "broken"],
    "patterns": []
  },
  "pipeline": [
    {
      "stage": "diagnosis",
      "required": true,
      "outputs": ["bug-report.md", "root-cause.md"],
      "agents": ["backend-agent", "frontend-agent"],
      "agent_mode": "parallel",
      "skills": ["systematic-debugging"],
      "description": "诊断问题，定位根因（前后端并行诊断）"
    },
    {
      "stage": "dev",
      "required": true,
      "outputs": ["test-for-bug", "fix"],
      "agents": ["frontend-agent", "backend-agent"],
      "agent_mode": "sequential",
      "skills": ["test-driven-development"],
      "constraints": ["test_must_fail_first"],
      "description": "TDD：写测试复现 Bug → 修复（串行，先确定根因再修复）"
    },
    {
      "stage": "qa",
      "required": true,
      "outputs": ["regression-test-report.md"],
      "agents": ["qa-agent"],
      "skills": ["test-plan"],
      "focus": "regression",
      "description": "回归测试，确保无新问题"
    }
  ],
  "gates": [
    {
      "name": "diagnosis_required",
      "description": "必须定位根因才能开始修复",
      "check": "stages.diagnosis.artifacts.includes('root-cause.md')",
      "blocker": "Dev 阻止：请先定位 Bug 根因（Diagnosis 阶段）。"
    },
    {
      "name": "test_must_fail_first",
      "description": "Bug 测试必须先失败（证明测试能捕获 Bug）",
      "check": "stages.dev.progress.test_failed_before_fix === true",
      "blocker": "修复阻止：测试必须先失败，证明能捕获 Bug。"
    }
  ],
  "rules": {
    "tdd": true,
    "sdd": false,
    "parallel_allowed": false
  },
  "execution_flow": {
    "diagnosis": {
      "sequence": 1,
      "next": ["dev"]
    },
    "dev": {
      "sequence": 2,
      "next": ["qa"],
      "tdd_cycle": ["RED (复现Bug)", "GREEN (修复)", "REFACTOR"]
    },
    "qa": {
      "sequence": 3,
      "focus": "regression"
    }
  }
}