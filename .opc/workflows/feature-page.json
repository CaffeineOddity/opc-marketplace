{
  "name": "feature-page",
  "description": "完整功能页面开发（前后端 + TDD + SDD）",
  "triggers": {
    "keywords": ["独立页面", "功能页面", "单页面", "landing page", "详情页", "页面开发"],
    "patterns": []
  },
  "pipeline": [
    {
      "stage": "product",
      "required": true,
      "outputs": ["spec.md", "page-spec.md", "api-spec.yaml"],
      "agents": ["product-agent", "backend-architect"],
      "agent_mode": "parallel",
      "skills": ["spec-driven-development", "openapi-spec","brainstorm"],
      "description": "定义页面需求 + API 规格（并行）"
    },
    {
      "stage": "design",
      "required": true,
      "outputs": ["wireframes/", "ui-spec.md"],
      "agents": ["web-agent", "design-reviewer"],
      "agent_mode": "sequential",
      "skills": ["ui-design","ui-ux-pro-max"],
      "description": "页面设计 + 评审（串行）"
    },
    {
      "stage": "dev",
      "required": true,
      "outputs": ["tests/", "frontend/", "backend/"],
      "agents": ["frontend-agent", "backend-agent"],
      "agent_mode": "parallel",
      "skills": ["test-driven-development"],
      "constraints": ["tdd_red_first", "api_contract_test"],
      "description": "前后端并行开发（TDD）"
    },
    {
      "stage": "qa",
      "required": true,
      "outputs": ["test-report.md", "e2e-test-report.md"],
      "agents": ["qa-agent"],
      "agent_mode": "sequential",
      "skills": ["test-plan", "e2e-test"],
      "description": "集成测试 + E2E 测试"
    }
  ],
  "gates": [
    {
      "name": "design_required",
      "description": "必须有设计稿才能开发",
      "check": "stages.design.artifacts.includes('wireframes/')",
      "blocker": "Dev 阻止：缺少设计稿。请先完成 Design 阶段。"
    },
    {
      "name": "api_spec_required",
      "description": "必须有 API 规格",
      "check": "stages.product.artifacts.includes('api-spec.yaml')",
      "blocker": "Dev 阻止：缺少 API 规格。请在 Product 阶段定义 API。"
    },
    {
      "name": "tdd_red_first",
      "description": "必须先写失败测试",
      "check": "stages.dev.progress.red_complete === true",
      "blocker": "实现阻止：请先写失败测试（RED 阶段）。"
    }
  ],
  "rules": {
    "tdd": true,
    "sdd": true,
    "parallel_allowed": true
  },
  "execution_flow": {
    "product": {
      "sequence": 1,
      "next": ["design"],
      "outputs_required": ["spec.md", "api-spec.yaml"]
    },
    "design": {
      "sequence": 2,
      "next": ["dev"],
      "outputs_required": ["wireframes/"]
    },
    "dev": {
      "sequence": 3,
      "next": ["qa"],
      "tdd_cycle": ["RED", "GREEN", "REFACTOR"],
      "parallel_agents": ["frontend-agent", "backend-agent"]
    },
    "qa": {
      "sequence": 4,
      "next": []
    }
  }
}
