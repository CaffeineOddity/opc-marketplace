{
  "name": "api-development",
  "description": "API development with API-First + TDD",
  "triggers": {
    "keywords": ["API", "接口", "REST", "GraphQL", "endpoint", "API开发"],
    "patterns": []
  },
  "pipeline": [
    {
      "stage": "product",
      "required": true,
      "outputs": ["api-spec.yaml"],
      "agents": ["backend-architect"],
      "skills": ["openapi-spec"],
      "description": "API 规格设计（OpenAPI/AsyncAPI）"
    },
    {
      "stage": "dev",
      "required": true,
      "outputs": ["contract-test", "implementation"],
      "agents": ["backend-agent"],
      "skills": ["test-driven-development"],
      "constraints": ["contract_test_first"],
      "description": "契约测试优先，然后实现"
    },
    {
      "stage": "qa",
      "required": true,
      "outputs": ["contract-compliance-report.md"],
      "agents": ["qa-agent"],
      "skills": [],
      "focus": "contract",
      "description": "契约合规验证"
    }
  ],
  "gates": [
    {
      "name": "api_spec_required",
      "description": "必须有 API Spec 才能开发",
      "check": "stages.product.artifacts.includes('api-spec.yaml')",
      "blocker": "Dev 阻止：缺少 API Spec。请先设计 API 规格。"
    },
    {
      "name": "contract_test_first",
      "description": "必须先写契约测试",
      "check": "stages.dev.progress.contract_test_written === true",
      "blocker": "实现阻止：请先写契约测试。"
    }
  ],
  "rules": {
    "tdd": true,
    "sdd": true,
    "parallel_allowed": false,
    "api_first": true
  }
}