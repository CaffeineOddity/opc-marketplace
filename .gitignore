.omc
.env
.claude/settings.local.json
**/node_modules/

# Source build artifacts (not committed)
src/mcp/dist/
src/mcp/node_modules/
src/mcp/package-lock.json

# OPC state - personal session data, don't commit
.opc/state/**/*

# Keep these (optional but recommended):
# .opc/memory/          - project decisions, useful for team
# .opc/state/checkpoints/ - rollback points
# .opc/logs/            - execution logs
