{
  "name": "security-fix",
  "description": "Security vulnerability fix with Security Audit",
  "triggers": {
    "keywords": ["安全", "漏洞", "vulnerability", "CVE", "security", "漏洞修复"],
    "patterns": []
  },
  "pipeline": [
    {
      "stage": "diagnosis",
      "required": true,
      "outputs": ["security-report.md", "cvss-score.md"],
      "agents": ["security-auditor"],
      "skills": [],
      "description": "安全漏洞评估"
    },
    {
      "stage": "dev",
      "required": true,
      "outputs": ["security-test", "fix"],
      "agents": ["frontend-agent", "backend-agent"],
      "agent_mode": "parallel",
      "skills": ["test-driven-development"],
      "constraints": ["tdd_red_first"],
      "description": "TDD：安全测试 → 修复（前后端并行）"
    },
    {
      "stage": "security-audit",
      "required": true,
      "outputs": ["owasp-checklist.md", "audit-report.md"],
      "agents": ["security-auditor"],
      "skills": [],
      "description": "安全审计"
    },
    {
      "stage": "qa",
      "required": true,
      "outputs": ["regression-test-report.md", "security-test-report.md"],
      "agents": ["qa-agent"],
      "skills": ["test-plan"],
      "description": "回归测试 + 安全测试"
    }
  ],
  "gates": [
    {
      "name": "security_audit_required",
      "description": "安全修复必须通过安全审计",
      "check": "stages['security-audit'].status === 'completed' && stages['security-audit'].audit_passed === true",
      "blocker": "Ship 阻止：安全审计未通过。"
    }
  ],
  "rules": {
    "tdd": true,
    "sdd": false,
    "parallel_allowed": false
  }
}